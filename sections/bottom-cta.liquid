{% schema %}
{
  "name": "Bottom CTA",
  "settings": [
    { "type": "text", "id": "product_handle", "label": "Product Handle", "default": "personalized-gemstone-urn-necklace" }
  ],
  "presets": [{ "name": "Bottom CTA" }]
}
{% endschema %}

<section class="bottom-cta" id="bottom-cta">
  <div class="price-row">
    <span class="old-price">$69.99</span>
    <span class="new-price">$34.99</span>
  </div>
  <div class="save-tag">SAVE 50% — TODAY ONLY</div>

  {% assign product = all_products[section.settings.product_handle] %}
  {% if product and product.variants.size > 0 %}
    <button class="btn-primary buy-now-btn" data-variant-id="{{ product.variants.first.id }}">Get Your Urn Necklace →</button>
  {% else %}
    <a href="/products/{{ section.settings.product_handle }}" class="btn-primary">Get Your Urn Necklace →</a>
  {% endif %}

  <div class="urgency" style="margin-top:20px;">
    <span class="dot"></span> Only <strong>7 pieces</strong> remaining — secure yours now
    <div style="margin-top:10px;height:6px;background:#f0ddd0;border-radius:3px;overflow:hidden;max-width:300px;margin-left:auto;margin-right:auto;">
      <div style="height:100%;width:12%;background:linear-gradient(90deg,var(--danger),#e74c3c);border-radius:3px;"></div>
    </div>
    <div style="font-size:11px;color:var(--muted);margin-top:4px;">Stock: ████░░░░░░░░░░░░░░ 12% remaining</div>
  </div>
</section>

<!-- Sticky Mobile CTA -->
<div class="sticky-cta">
  <div>
    <div class="price-sm">$34.99</div>
    <div class="old-sm">$69.99</div>
  </div>
  <div class="badge-sm">50% OFF</div>
  {% if product and product.variants.size > 0 %}
    <button class="btn-sm buy-now-btn" data-variant-id="{{ product.variants.first.id }}">Get Yours →</button>
  {% else %}
    <a href="/products/{{ section.settings.product_handle }}" class="btn-sm">Get Yours →</a>
  {% endif %}
</div>

<!-- Footer -->
<footer>
  <div style="max-width:700px;margin:0 auto;display:flex;flex-wrap:wrap;justify-content:center;gap:24px;font-size:13px;color:var(--muted);font-family:sans-serif;">
    <a href="/policies/privacy-policy">Privacy Policy</a>
    <a href="/policies/terms-of-service">Terms of Service</a>
    <a href="/policies/refund-policy">Refund Policy</a>
    <a href="/pages/contact">Contact Us</a>
    <a href="mailto:support@lunveo.com">support@lunveo.com</a>
  </div>
  <div style="margin-top:16px;font-size:12px;color:#b0a095;font-family:sans-serif;">
    &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
  </div>
</footer>
