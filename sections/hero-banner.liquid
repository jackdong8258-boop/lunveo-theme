<style>
.hero-banner { style defined in base.css }
</style>

<section class="hero-banner" id="hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-content">
        <div class="hero-badge animate-in">{{ section.settings.badge_text }}</div>
        
        <h1 class="hero-title animate-in delay-1">{{ section.settings.heading }}</h1>
        
        <p class="hero-subtitle animate-in delay-2">{{ section.settings.subtitle }}</p>
        
        <!-- Urgency Timer -->
        <div class="urgency-bar animate-in delay-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>Offer ends in:</span>
          <span class="timer-digits" id="hero-timer">
            <span class="timer-digit" id="hrs">04</span>:<span class="timer-digit" id="mins">59</span>:<span class="timer-digit" id="secs">37</span>
          </span>
        </div>
        
        <!-- Pricing -->
        <div class="hero-pricing animate-in delay-3">
          <span class="price-old">{{ section.settings.old_price }}</span>
          <span class="price-new">{{ section.settings.new_price }}</span>
          <span class="price-save">{{ section.settings.save_text }}</span>
        </div>
        
        <!-- CTA Buttons -->
        <div class="hero-cta animate-in delay-3">
          <a href="#buy" class="btn btn-primary btn-lg buy-now-btn" data-variant-id="{{ all_products[section.settings.product_handle].selected_or_first_available_variant.id }}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            {{ section.settings.cta_text }}
          </a>
        </div>
        
        <div class="payment-trust animate-in delay-4">
          <svg width="40" height="24" viewBox="0 0 40 24" fill="none"><rect width="40" height="24" rx="4" fill="#003087"/><text x="20" y="15" text-anchor="middle" fill="white" font-size="8" font-weight="bold">PayPal</text></svg>
          <svg width="40" height="24" viewBox="0 0 40 24" fill="none"><rect width="40" height="24" rx="4" fill="#1A1F71"/><text x="20" y="15" text-anchor="middle" fill="white" font-size="8" font-weight="bold">VISA</text></svg>
          <svg width="40" height="24" viewBox="0 0 40 24" fill="none"><rect width="40" height="24" rx="4" fill="#EB001B"/><circle cx="15" cy="12" r="7" fill="#EB001B"/><circle cx="25" cy="12" r="7" fill="#F79E1B"/></svg>
        </div>
        
        <div class="stock-alert animate-in delay-4">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          Only <strong>47 pieces</strong> left at this price — order before they're gone!
        </div>
      </div>
      
      <div class="hero-image-wrapper animate-in delay-2">
        {% if section.settings.hero_image != blank %}
          <img src="{{ section.settings.hero_image }}" alt="Personalized Gemstone Urn Necklace" class="hero-image" loading="eager" />
        {% endif %}
        <div class="hero-image-float">
          <div class="float-number">4.9</div>
          <div class="float-label">Avg Rating</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Mobile CTA Bar -->
<div class="mobile-cta-bar">
  <div class="mobile-cta-inner">
    <div class="mobile-price-info">
      <div class="mobile-price-new">{{ section.settings.new_price }}</div>
      <div class="mobile-price-old">{{ section.settings.old_price }}</div>
    </div>
    <a href="#buy" class="btn btn-primary btn-sm buy-now-btn" data-variant-id="{{ all_products[section.settings.product_handle].selected_or_first_available_variant.id }}">Buy Now</a>
  </div>
</div>

<script>
// Countdown timer
(function(){
  function pad(n){return n<10?'0'+n:n;}
  var end=new Date();end.setHours(end.getHours()+4);end.setMinutes(end.getMinutes()+59);end.setSeconds(end.getSeconds()+37);
  var iv=setInterval(function(){
    var now=new Date(),d=Math.max(0,end-now);
    if(d<=0){clearInterval(iv);return;}
    var h=Math.floor(d/3600000),m=Math.floor(d%3600000/60000),s=Math.floor(d%60000/1000);
    document.getElementById('hrs').textContent=pad(h);
    document.getElementById('mins').textContent=pad(m);
    document.getElementById('secs').textContent=pad(s);
  },1000);
})();
</script>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {"type":"text","id":"badge_text","label":"Badge Text","default":"Personalized Memorial Jewelry"},
    {"type":"html","id":"heading","label":"Heading","default":"Keep Them <em>Close</em> to Your Heart, <em>Always</em>."},
    {"type":"textarea","id":"subtitle","label":"Subtitle","default":"A beautiful vintage cylinder urn necklace with a genuine birthstone to hold a small portion of ashes, forever."},
    {"type":"product","id":"product_handle","label":"Product"},
    {"type":"text","id":"old_price","label":"Old Price","default":"$69.99"},
    {"type":"text","id":"new_price","label":"New Price","default":"$34.99"},
    {"type":"text","id":"save_text","label":"Save Text","default":"SAVE 50% - LIMITED TIME"},
    {"type":"text","id":"cta_text","label":"CTA Button Text","default":"Buy Now - $34.99"},
    {"type":"image_picker","id":"hero_image","label":"Hero Image"}
  ],
  "presets": [{"name":"Hero Banner"}]
}
{% endschema %}