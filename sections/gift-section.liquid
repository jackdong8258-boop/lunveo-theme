{% schema %}
{
  "name": "Gift Section",
  "settings": [
    { "type": "text", "id": "product_handle", "label": "Product Handle", "default": "personalized-gemstone-urn-necklace" }
  ],
  "presets": [{ "name": "Gift Section" }]
}
{% endschema %}

<section class="gift-section">
  <h2>The Most Meaningful Gift You'll Ever Give.</h2>
  <p>For someone who just lost their best friend. For a mother grieving her child. For yourself, because you need something to hold onto.</p>
  <p>This isn't just jewelry. It's the weight of a paw in your palm. The warmth of a memory pressed against your chest. A <strong>physical connection</strong> to someone you refuse to forget.</p>

  <div style="max-width:420px;margin:30px auto 0;text-align:center;">
    <div class="save-tag" style="margin-bottom:14px;">SAVE 50% — LIMITED TIME</div>
    {% assign product = all_products[section.settings.product_handle] %}
    {% if product and product.variants.size > 0 %}
      <button class="btn-primary buy-now-btn" data-variant-id="{{ product.variants.first.id }}">Get Yours Now →</button>
    {% else %}
      <a href="/products/{{ section.settings.product_handle }}" class="btn-primary">Get Yours Now →</a>
    {% endif %}
  </div>
</section>
