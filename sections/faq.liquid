{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "q1", "label": "Question 1", "default": "Is the pendant truly leak-proof?" },
    { "type": "textarea", "id": "a1", "label": "Answer 1", "default": "Yes. The screw-top design creates a tight, secure seal. Hundreds of customers wear theirs through showers, rain, and daily life with zero issues." },
    { "type": "text", "id": "q2", "label": "Question 2", "default": "How much ashes can it hold?" },
    { "type": "textarea", "id": "a2", "label": "Answer 2", "default": "The cylinder chamber holds a small, meaningful portion — approximately 0.5-1 gram. The included funnel kit makes it easy." },
    { "type": "text", "id": "q3", "label": "Question 3", "default": "Is this only for human ashes, or pet ashes too?" },
    { "type": "textarea", "id": "a3", "label": "Answer 3", "default": "Both. Many of our customers use it for beloved pets as well as for family members." },
    { "type": "text", "id": "q4", "label": "Question 4", "default": "What chain length should I choose?" },
    { "type": "textarea", "id": "a4", "label": "Answer 4", "default": "16\" sits at the collarbone, 18\" at the mid-neck (most popular), 20\" at the upper chest, 22\" for a longer drop." },
    { "type": "text", "id": "q5", "label": "Question 5", "default": "Can I return it if I change my mind?" },
    { "type": "textarea", "id": "a5", "label": "Answer 5", "default": "Absolutely. We offer a 100% money-back guarantee within 30 days. No questions asked." },
    { "type": "text", "id": "q6", "label": "Question 6", "default": "How long does shipping take?" },
    { "type": "textarea", "id": "a6", "label": "Answer 6", "default": "Free worldwide shipping takes 7–12 business days. Express shipping (3–5 days) is available." }
  ],
  "presets": [{ "name": "FAQ" }]
}
{% endschema %}

<section class="faq">
  <h2>Questions You Might Have</h2>

  <div class="faq-item open">
    <div class="faq-q">{{ section.settings.q1 }}</div>
    <div class="faq-a">{{ section.settings.a1 }}</div>
  </div>
  <div class="faq-item">
    <div class="faq-q">{{ section.settings.q2 }}</div>
    <div class="faq-a">{{ section.settings.a2 }}</div>
  </div>
  <div class="faq-item">
    <div class="faq-q">{{ section.settings.q3 }}</div>
    <div class="faq-a">{{ section.settings.a3 }}</div>
  </div>
  <div class="faq-item">
    <div class="faq-q">{{ section.settings.q4 }}</div>
    <div class="faq-a">{{ section.settings.a4 }}</div>
  </div>
  <div class="faq-item">
    <div class="faq-q">{{ section.settings.q5 }}</div>
    <div class="faq-a">{{ section.settings.a5 }}</div>
  </div>
  <div class="faq-item">
    <div class="faq-q">{{ section.settings.q6 }}</div>
    <div class="faq-a">{{ section.settings.a6 }}</div>
  </div>
</section>
